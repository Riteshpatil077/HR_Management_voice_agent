# =============================================================================
# HR Voice Agent Platform — .gitignore
# =============================================================================

# ── Secrets & Environment Variables ─────────────────────────────────────────
.env
.env.*
!.env.example
!.env.local.example
frontend/.env.local
frontend/.env.*.local


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
sdist/
wheels/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg

# Virtual Environments
.venv/
venv/
env/
ENV/

# Testing & Coverage
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.pytest_cache/
.tox/
.nox/

# MyPy / Pyright type checker
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# Ruff linter cache
.ruff_cache/

# Distribution / packaging
MANIFEST


# ── Next.js / Node ────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/.vercel/

# NPM / Yarn / PNPM
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json.bak


# ── Docker ────────────────────────────────────────────────────────────────────
# Named volumes are managed by Docker — don't commit their data
docker-data/

# Local override files
docker-compose.override.yml
docker-compose.local.yml


# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite3
*.sqlite
*.dump
*.sql.gz
pgdata/
postgres-data/


# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*
*.out


# ── IDE & Editors ─────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db


# ── Security — Private Keys & Certificates ────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
secrets/
certs/


# ── AI / ML Artefacts ─────────────────────────────────────────────────────────
models/
*.onnx
*.pt
*.pkl
*.bin


# ── HashiCorp Vault ───────────────────────────────────────────────────────────
.vault-token
vault-data/


# ── Monitoring Data ───────────────────────────────────────────────────────────
prometheus-data/
grafana-data/
loki-data/
tempo-data/
jaeger-data/


# ── Miscellaneous ─────────────────────────────────────────────────────────────
.cache/
.tmp/
tmp/
temp/
.terraform/
*.tfstate
*.tfstate.backup
