{
  "id": null,
  "uid": "hr-voice-overview",
  "title": "HR Voice Agent — Platform Overview",
  "tags": ["hr-voice-agent"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Total HTTP Requests / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "req/s",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "error %",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
