# =============================================================================
# HR Voice Agent Platform — Environment Configuration
# =============================================================================
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# All secrets are sourced from HashiCorp Vault in production.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_NAME=hr-voice-agent
APP_VERSION=3.0.0
DEBUG=false
LOG_LEVEL=INFO
WORKERS=4
PORT=8000

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-64-char-random-string
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_HOSTS=*
CORS_ORIGINS=http://localhost:3000,https://app.yourdomain.com

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=                  # Only for dev. Prod uses Kubernetes auth.
VAULT_ROLE=hr-voice-agent
VAULT_NAMESPACE=              # For Vault Enterprise namespaces
VAULT_MOUNT_PATH=secret
VAULT_PKI_MOUNT=pki
VAULT_PKI_ROLE=hr-voice-agent

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hrvoice:password@postgres:5432/hrvoice
DATABASE_URL_REPLICA_1=postgresql+asyncpg://hrvoice:password@postgres-replica-1:5432/hrvoice
DATABASE_URL_REPLICA_2=postgresql+asyncpg://hrvoice:password@postgres-replica-2:5432/hrvoice
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ── Redis Cluster ─────────────────────────────────────────────────────────────
REDIS_NODES=redis-node-1:7001,redis-node-2:7002,redis-node-3:7003,redis-node-4:7004,redis-node-5:7005,redis-node-6:7006
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_SENTINEL_NODES=sentinel-1:26379,sentinel-2:26380,sentinel-3:26381
REDIS_SENTINEL_MASTER=mymaster
REDIS_DEFAULT_TTL=3600
REDIS_SESSION_TTL=1800
REDIS_CACHE_TTL=300

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_HEARTBEAT=60
RABBITMQ_CONNECTION_TIMEOUT=5

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=30

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_TIMEOUT=30

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AI...
GEMINI_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
GEMINI_TIMEOUT=30

# ── Ollama (local fallback) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=60

# ── Deepgram STT ─────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_TIMEOUT=60

# ── ElevenLabs TTS ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_TIMEOUT=30

# ── Exotel (India telephony primary) ─────────────────────────────────────────
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_FROM_NUMBER=0XXXXXXXXXX
EXOTEL_WEBHOOK_HMAC_SECRET=

# ── Twilio (global fallback) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_WEBHOOK_AUTH_TOKEN=

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────────
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_API_VERSION=v19.0

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/auth/google/callback

# ── Microsoft Calendar ────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=https://api.yourdomain.com/auth/microsoft/callback

# ── HubSpot CRM ───────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_WEBHOOK_SECRET=

# ── Salesforce CRM ────────────────────────────────────────────────────────────
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login.salesforce.com

# ── Zoho CRM ──────────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_REGION=IN

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_DR_REGION=ap-southeast-1
AWS_S3_BUCKET=hr-voice-agent-prod
AWS_S3_BUCKET_DR=hr-voice-agent-dr
AWS_KMS_KEY_ID=
AWS_ACCESS_KEY_ID=               # Use IAM roles in production, not keys
AWS_SECRET_ACCESS_KEY=

# ── OPA Policy Engine ─────────────────────────────────────────────────────────
OPA_URL=http://opa:8181
OPA_POLICY_PATH=hr_voice/authz
OPA_TIMEOUT=5

# ── LangSmith AI Observability ────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hr-voice-agent-prod
LANGCHAIN_TRACING_V2=true

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=hr-voice-agent
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# ── PgBouncer ─────────────────────────────────────────────────────────────────
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432
PGBOUNCER_POOL_SIZE=50
PGBOUNCER_MAX_CLIENT_CONN=100

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_VOICE_CLONE_ENABLED=true
FEATURE_WHATSAPP_ENABLED=true
FEATURE_MULTI_LLM_ROUTING=true
FEATURE_AUDIT_LOG_ENABLED=true
FEATURE_COST_TRACKING_ENABLED=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_VOICE=20/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_WEBHOOK=500/minute
